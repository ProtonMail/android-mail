  <string name="edm_code_not_recognized">代碼未能識別。請再試一次。</string>
  <string name="edm_code_verifying">正在驗證…</string>
  <string name="edm_missing_camera_permission_headline">允許存取相機</string>
  <string name="edm_missing_camera_permission_body">若要使用 QR Code 登入，你需要允許 %1$s 存取你的相機。你可以在你的裝置設定中進行此操作。</string>
  <string name="edm_missing_camera_permission_footer">一切由你掌控：你隨時可以在你的裝置設定中進行變更。</string>
  <string name="edm_missing_camera_permission_settings">設定</string>
  <string name="intro_origin_sign_in_title">登入服務</string>
  <string name="intro_origin_sign_in_subtitle">如何使用 QR Code 登入</string>
  <string name="intro_origin_sign_in_hint_1">1. 在你想要登入的裝置上，開啟任何 Proton 應用程式。</string>
  <string name="intro_origin_sign_in_hint_2">2. 在登入畫面上，選取 <b>忘記密碼</b> 或 <b>登入時遇到問題？</b> (在行動應用程式上，請選取 <b>說明</b>)。</string>
  <string name="intro_origin_sign_in_hint_3">3. 選取 <b>使用 QR Code 登入</b>。畫面上會顯示一個 QR Code。</string>
  <string name="intro_origin_sign_in_hint_4">4. 在此裝置上，按下 <b>掃描 QR Code</b> 並掃描代碼。</string>
  <string name="intro_origin_sign_in_tips">安全性提示</string>
  <string name="intro_origin_sign_in_tip_1">請小心含有 QR Code 的訊息。請只在信任來源的情況下掃描代碼。</string>
  <string name="intro_origin_sign_in_tip_2">Proton 絕不會無故聯絡你，要求你使用 QR Code 登入。</string>
  <string name="intro_origin_sign_in_tip_3">Proton 絕不會要求你掃描非來自 <b>https://proton.me</b> 或 Proton 官方應用程式的 QR Code。</string>
  <string name="intro_origin_sign_in_begin">掃描 QR 碼</string>
  <string name="intro_origin_biometrics_title">解鎖你的裝置以繼續</string>
  <string name="manual_code_input_title">手動輸入代碼</string>
  <string name="manual_code_input_description">若要存取你想要登入之裝置的代碼，請輕點登入畫面說明選單中的 <b>使用 QR Code 登入</b> 按鈕，然後輕點 <b>手動輸入密鑰</b>。</string>
  <string name="manual_code_input_code_label">程式碼</string>
  <string name="manual_code_input_clear_code">清除</string>
  <string name="manual_code_input_submit">繼續</string>
  <string name="origin_success_signed_in">存取已共享</string>
  <string name="origin_success_ack">返回設定</string>
  <string name="qr_code_scan_hint">請將 QR Code 放置在方框內</string>
  <string name="qr_code_scan_enter_manually">手動輸入代碼</string>
  <string name="target_sign_in_title">使用 QR code 登入</string>
  <string name="target_sign_in_scan_code">如何使用其他裝置登入</string>
  <string name="target_sign_in_instruction_1">1. 取得另一部已登入你 Proton 帳號的裝置</string>
  <string name="target_sign_in_instruction_2">2. 使用該裝置，開啟任何 Proton 應用程式並選取 <b>設定</b></string>
  <string name="target_sign_in_instruction_3">3. 選取 <b>在其他裝置上登入 → 掃描 QR Code</b></string>
  <string name="target_sign_in_instruction_4">4. 掃描代碼以登入</string>
  <string name="target_sign_in_error_title">我們無法為你登入</string>
  <string name="target_sign_in_retryable_error">請嘗試產生新的 QR Code。</string>
  <string name="target_sign_in_error_new_qr">產生 QR Code</string>
  <string name="target_sign_in_error_back_to_signin">返回登入</string>
  <string name="target_sign_in_learn_more">了解更多</string>
  <string name="proton_error_non_processable_actions">一項或多項操作無法處理。請登出並重新登入您的帳號。</string>
</resources>
