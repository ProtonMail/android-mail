<resources>
  <string name="spotlight_screen_version_text">版本 %s</string>
  <string name="spotlight_screen_title">Proton Mail 的新功能</string>
  <string name="spotlight_feature_item_discreet_icon_title">隐藏图标</string>
  <string name="spotlight_feature_item_discreet_icon_description">保留默认的Proton Mail图标，或将其伪装成一个通用的图标以增强隐私性。</string>
  <string name="spotlight_feature_item_tracking_protection_title">跟踪防护</string>
  <string name="spotlight_feature_item_tracking_protection_description">查看谁试图使用隐藏像素和跟踪链接监控您，以及阻止了多少次尝试。</string>
  <string name="spotlight_feature_item_encryption_locks_title">加密锁定</string>
  <string name="spotlight_feature_item_encryption_locks_description">使用锁图标来识别和验证保护您邮件的加密类型。</string>
  <string name="spotlight_feature_item_headers_html_title">查看标题和 HTML</string>
  <string name="spotlight_feature_item_headers_html_description">检查可疑消息以确认其真实性并发现任何隐藏的跟踪元素。</string>
  <string name="spotlight_screen_got_it">了解</string>
  <!-- Category View Spotlight -->
  <string name="spotlight_screen_category_view_title">探索 Proton Mail 的新功能</string>
  <string name="spotlight_screen_category_view_ui_enhancements_title">界面增强</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">流畅滚动、全新布局等更多改进！</string>
  <string name="spotlight_screen_category_view_unread_filter_title">未读筛选器</string>
  <string name="spotlight_screen_category_view_unread_filter_subtitle">全新外观与位置，更易于访问！</string>
  <string name="spotlight_screen_category_view_categories_title">邮件分类</string>
  <string name="spotlight_screen_category_view_categories_subtitle">自动分类收到的邮件！</string>
  <string name="spotlight_screen_category_view_main_b2c_title">查看新功能，\n跳过其余内容。</string>
  <string name="spotlight_screen_category_view_main_b2c_subtitle">聚焦未读邮件，只需轻点一下，即可轻松切换查看所有邮件或仅查看未读邮件。</string>
  <string name="spotlight_screen_category_view_main_b2b_title">随时掌握新邮件和未读邮件</string>
  <string name="spotlight_screen_category_view_main_b2b_subtitle">未读筛选器现在更加显眼且触手可及，让您快速浏览并对未读邮件采取行动。</string>
  <string name="spotlight_screen_category_view_secondary_b2c_title">迎接更有序的收件箱</string>
  <string name="spotlight_screen_category_view_secondary_b2c_subtitle">借助全新的邮件分类功能，只有重要且紧急的邮件才会进入主收件箱，其他邮件会被自动归类到对应分类中。</string>
  <string name="spotlight_screen_category_view_secondary_b2b_title">告别分类，\n告别干扰。</string>
  <string name="spotlight_screen_category_view_secondary_b2b_subtitle">不再被资讯、更新和非紧急邮件打扰。有了新的邮件分类功能，只有重要邮件才会进入您的主收件箱。</string>
  <string name="spotlight_screen_category_view_button_continue">继续</string>
  <string name="spotlight_screen_category_view_button_try">试用分类</string>
  <string name="spotlight_screen_category_view_button_dismiss">不使用分类</string>
</resources>
