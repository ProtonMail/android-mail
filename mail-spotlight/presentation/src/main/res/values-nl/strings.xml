<resources>
  <string name="spotlight_screen_version_text">Versie %s</string>
  <string name="spotlight_screen_title">Nieuw in Proton Mail</string>
  <string name="spotlight_feature_item_discreet_icon_title">Onopvallend app-icoon</string>
  <string name="spotlight_feature_item_discreet_icon_description">Houd het standaard Proton Mail-pictogram of vermom het met een generiek pictogram voor meer privacy.</string>
  <string name="spotlight_feature_item_tracking_protection_title">Trackerbescherming</string>
  <string name="spotlight_feature_item_tracking_protection_description">Bekijk wie u heeft geprobeerd te monitoren met verborgen pixels en trackingkoppelingen, en hoeveel pogingen er zijn geblokkeerd.</string>
  <string name="spotlight_feature_item_encryption_locks_title">Versleutelingssloten</string>
  <string name="spotlight_feature_item_encryption_locks_description">Gebruik de slotpictogrammen om het type versleuteling te identificeren en te verifiëren dat uw berichten beschermt.</string>
  <string name="spotlight_feature_item_headers_html_title">Bekijk headers en HTML</string>
  <string name="spotlight_feature_item_headers_html_description">Controleer verdachte berichten om hun authenticiteit te bevestigen en eventuele verborgen traceerelementen bloot te leggen.</string>
  <string name="spotlight_screen_got_it">Begrepen</string>
  <!-- Category View Spotlight -->
  <string name="spotlight_screen_category_view_title">Ontdek wat er nieuw is\nin Proton Mail</string>
  <string name="spotlight_screen_category_view_ui_enhancements_title">Verbeterde visuele vormgeving</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">Vloeiend scrollen, vernieuwde lay-out en meer.</string>
  <string name="spotlight_screen_category_view_unread_filter_title">Ongelezen filter</string>
  <string name="spotlight_screen_category_view_unread_filter_subtitle">Nieuwe look en locatie voor betere bereikbaarheid.</string>
  <string name="spotlight_screen_category_view_categories_title">E-mailcategorieën</string>
  <string name="spotlight_screen_category_view_categories_subtitle">Automatische sortering van binnenkomende e-mails.</string>
  <string name="spotlight_screen_category_view_main_b2c_title">Bekijk wat er nieuw is.\nSla de rest over.</string>
  <string name="spotlight_screen_category_view_main_b2c_subtitle">Leg de focus op ongelezen berichten. Of niet. Met een simpele tik switcht u tussen alle e-mails en alleen de ongelezen berichten.</string>
  <string name="spotlight_screen_category_view_main_b2b_title">Blijf op de hoogte van nieuwe en\nongelezen e-mails.</string>
  <string name="spotlight_screen_category_view_main_b2b_subtitle">De filter voor ongelezen e-mails is nu beter zichtbaar en direct beschikbaar, zodat u snel ongelezen e-mails kunt scannen en actie kunt ondernemen.</string>
  <string name="spotlight_screen_category_view_secondary_b2c_title">Verwelkom uw eigen meer georganiseerde inbox.</string>
  <string name="spotlight_screen_category_view_secondary_b2c_subtitle">Met nieuwe e-mailcategorieën komen alleen belangrijke berichten in uw primaire inbox terecht. Al het andere wordt in categorieën geordend.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_title">Hallo categorieën.\nVaarwel afleidingen.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_subtitle">Laat u niet langer afleiden door nieuwsbrieven, updates en niet-urgente e-mails. Dankzij de nieuwe e-mailcategorieën komen alleen belangrijke berichten in uw primaire inbox terecht.</string>
  <string name="spotlight_screen_category_view_button_continue">Doorgaan</string>
  <string name="spotlight_screen_category_view_button_try">Probeer categorieën</string>
  <string name="spotlight_screen_category_view_button_dismiss">Ga verder zonder categorieën</string>
</resources>
