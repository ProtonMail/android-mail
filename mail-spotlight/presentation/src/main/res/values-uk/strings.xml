<resources>
  <string name="spotlight_screen_version_text">Версія %s</string>
  <string name="spotlight_screen_title">Що нового в Proton Mail</string>
  <string name="spotlight_feature_item_discreet_icon_title">Непомітний значок</string>
  <string name="spotlight_feature_item_discreet_icon_description">Залиште стандартну піктограму Proton Mail або замаскуйте її під звичайну для більшої приватності.</string>
  <string name="spotlight_feature_item_tracking_protection_title">Захист від відстеження</string>
  <string name="spotlight_feature_item_tracking_protection_description">Дивіться, хто намагався стежити за вами за допомогою прихованих пікселів та посилань для відстеження, і скільки спроб було заблоковано.</string>
  <string name="spotlight_feature_item_encryption_locks_title">Шифрувальні замки</string>
  <string name="spotlight_feature_item_encryption_locks_description">Використовуйте значки замків, щоб визначити та перевірити тип шифрування, що захищає ваші повідомлення.</string>
  <string name="spotlight_feature_item_headers_html_title">Перегляд заголовків та HTML</string>
  <string name="spotlight_feature_item_headers_html_description">Перевіряйте підозрілі повідомлення, щоб підтвердити їхню автентичність та виявити будь-які приховані елементи відстеження.</string>
  <string name="spotlight_screen_got_it">Зрозуміло</string>
  <!-- Category View Spotlight -->
  <string name="spotlight_screen_category_view_title">Дізнайтеся, що нового\nу Proton Mail</string>
  <string name="spotlight_screen_category_view_ui_enhancements_title">Покращення інтерфейсу</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">Плавне гортання, оновлений макет і багато іншого.</string>
  <string name="spotlight_screen_category_view_unread_filter_title">Фільтр непрочитаного</string>
  <string name="spotlight_screen_category_view_unread_filter_subtitle">Новий вигляд і розташування для зручнішого доступу.</string>
  <string name="spotlight_screen_category_view_categories_title">Категорії пошти</string>
  <string name="spotlight_screen_category_view_categories_subtitle">Автоматичне сортування вхідної пошти.</string>
  <string name="spotlight_screen_category_view_main_b2c_title">Дізнайтеся, що нового.\nПропустіть решту.</string>
  <string name="spotlight_screen_category_view_main_b2c_subtitle">Зосередьтеся на непрочитаних повідомленнях. Або ні. Перемикатися між усіма листами та лише непрочитаними можна одним простим дотиком.</string>
  <string name="spotlight_screen_category_view_main_b2b_title">Будьте в курсі нових та\nнепрочитаних листів</string>
  <string name="spotlight_screen_category_view_main_b2b_subtitle">Фільтр непрочитаного став помітнішим і тепер завжди під рукою, що дозволяє швидко переглядати пошту та опрацьовувати непрочитані листи.</string>
  <string name="spotlight_screen_category_view_secondary_b2c_title">Зустрічайте свою впорядкованішу поштову скриньку</string>
  <string name="spotlight_screen_category_view_secondary_b2c_subtitle">Завдяки новим категоріям пошти лише важливі та термінові повідомлення потрапляють у вашу основну теку «Вхідні». Усе інше впорядковується за категоріями.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_title">Привіт, категорії.\nПрощавайте, відволікання.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_subtitle">Досить відволікатися на розсилки, оновлення та нетермінові листи. Завдяки новим категоріям у вашу основну теку «Вхідні» потраплятимуть лише важливі повідомлення.</string>
  <string name="spotlight_screen_category_view_button_continue">Продовжити</string>
  <string name="spotlight_screen_category_view_button_try">Спробувати категорії</string>
  <string name="spotlight_screen_category_view_button_dismiss">Продовжити без категорій</string>
</resources>
