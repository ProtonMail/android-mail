<resources>
  <string name="spotlight_screen_version_text">버전 %s</string>
  <string name="spotlight_screen_title">Proton Mail의 새로운 기능</string>
  <string name="spotlight_feature_item_discreet_icon_title">숨겨진 아이콘</string>
  <string name="spotlight_feature_item_discreet_icon_description">기본 Proton Mail 아이콘을 유지하거나 개인 정보 보호를 위해 일반 아이콘으로 위장하세요.</string>
  <string name="spotlight_feature_item_tracking_protection_title">트래킹 보호</string>
  <string name="spotlight_feature_item_tracking_protection_description">숨겨진 픽셀 및 추적 링크로 누가 회원님을 감시하려고 했는지, 그리고 몇 건의 시도가 차단되었는지 확인하세요.</string>
  <string name="spotlight_feature_item_encryption_locks_title">암호화 잠금</string>
  <string name="spotlight_feature_item_encryption_locks_description">메시지를 보호하는 암호화 유형을 식별하고 확인하기 위해 잠금 아이콘을 사용하세요.</string>
  <string name="spotlight_feature_item_headers_html_title">HTML 및 헤더 보기</string>
  <string name="spotlight_feature_item_headers_html_description">숨겨진 추적 요소를 찾아내고 해당 메시지의 진위 여부를 확인하기 위해 의심스러운 메시지를 검사하세요.</string>
  <string name="spotlight_screen_got_it">확인</string>
  <!-- Category View Spotlight -->
  <string name="spotlight_screen_category_view_title">Proton Mail의\n새로운 기능 알아보기</string>
  <string name="spotlight_screen_category_view_ui_enhancements_title">UI 개선</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">부드러운 스크롤링, 레이아웃 업데이트 등.</string>
  <string name="spotlight_screen_category_view_unread_filter_title">읽지 않음 필터</string>
  <string name="spotlight_screen_category_view_unread_filter_subtitle">새 외관과 위치 조정으로 접근을 더욱 쉽게.</string>
  <string name="spotlight_screen_category_view_categories_title">이메일 카테고리</string>
  <string name="spotlight_screen_category_view_categories_subtitle">받은 메일을 자동 분류.</string>
  <string name="spotlight_screen_category_view_main_b2c_title">새 기능부터 살펴보고\n나머지는 나중에.</string>
  <string name="spotlight_screen_category_view_main_b2c_subtitle">읽지 않은 메시지에 집중해 보세요. 안 해도 좋고요. 탭 한 번으로 전체 메일과 읽지 않은 메일 사이를 왔다갔다.</string>
  <string name="spotlight_screen_category_view_main_b2b_title">새로운 이메일과\n읽지 않은 이메일 관리</string>
  <string name="spotlight_screen_category_view_main_b2b_subtitle">읽지 않음 필터의 시인성과 접근성 개선으로, 이제 읽지 않은 이메일을 빠르게 훑어보고 작업할 수 있습니다.</string>
  <string name="spotlight_screen_category_view_secondary_b2c_title">더욱 정돈된 편지함을 만나보세요</string>
  <string name="spotlight_screen_category_view_secondary_b2c_subtitle">새로운 이메일 카테고리를 사용하면 중요하고 긴급한 메시지만 우선 순위 받은 편지함에 저장됩니다. 다른 메시지는 모두 카테고리로 정리됩니다.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_title">어서와요, 카테고리.\n잘가요, 딴짓거리.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_subtitle">뉴스레터, 업데이트, 급하지 않은 이메일에 주의가 분산 되는 건 이제 그만. 새로운 이메일 카테고리 덕분에 기본 편지함에는 중요한 메시지만 들어온답니다.</string>
  <string name="spotlight_screen_category_view_button_continue">계속</string>
  <string name="spotlight_screen_category_view_button_try">카테고리 사용해보기</string>
  <string name="spotlight_screen_category_view_button_dismiss">카테고리 없이 계속</string>
</resources>
