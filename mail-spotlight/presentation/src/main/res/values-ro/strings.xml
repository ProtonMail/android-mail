  <string name="spotlight_screen_category_view_ui_enhancements_title">Îmbunătățiri ale interfeței</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">Derulare fluidă, aspect împrospătat și multe altele.</string>
