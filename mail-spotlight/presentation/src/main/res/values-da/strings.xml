<resources>
  <string name="spotlight_screen_version_text">Version %s</string>
  <string name="spotlight_screen_title">Nyt i Proton Mail</string>
  <string name="spotlight_feature_item_discreet_icon_title">Diskret ikon</string>
  <string name="spotlight_feature_item_discreet_icon_description">Behold standardikonet for Proton Mail, eller maskér den med et generisk ikon for at bedre privatlivsbeskyttelse.</string>
  <string name="spotlight_feature_item_tracking_protection_title">Beskyttelse mod sporing</string>
  <string name="spotlight_feature_item_tracking_protection_description">Se, hvem der forsøgte at overvåge dig med skjulte pixels og sporingslinks, og hvor mange forsøg der blev blokeret.</string>
  <string name="spotlight_feature_item_encryption_locks_title">Krypteringslåse</string>
  <string name="spotlight_feature_item_encryption_locks_description">Brug låseikonerne til at identificere og bekræfte den type kryptering, der beskytter dine beskeder.</string>
  <string name="spotlight_feature_item_headers_html_title">Vis overskrifter og HTML</string>
  <string name="spotlight_feature_item_headers_html_description">Undersøg mistænkelige beskeder for at bekræfte deres ægthed og afsløre eventuelle skjulte sporingskomponenter.</string>
  <string name="spotlight_screen_got_it">Forstået</string>
  <!-- Category View Spotlight -->
  <string name="spotlight_screen_category_view_title">Se hvad der er nyt i Proton Mail</string>
  <string name="spotlight_screen_category_view_ui_enhancements_title">UI-forbedringer</string>
  <string name="spotlight_screen_category_view_ui_enhancements_subtitle">Flydende scrolling, opdateret layout og meget mere.</string>
  <string name="spotlight_screen_category_view_unread_filter_title">Ulæst-filter</string>
  <string name="spotlight_screen_category_view_unread_filter_subtitle">Bedre tilgængelighed med nyt udseende og ny placering.</string>
  <string name="spotlight_screen_category_view_categories_title">E-mail-kategorier</string>
  <string name="spotlight_screen_category_view_categories_subtitle">Automatisk sortering af indgående mails</string>
  <string name="spotlight_screen_category_view_main_b2c_title">Se hvad der er nyt.\nSpring resten over.</string>
  <string name="spotlight_screen_category_view_main_b2c_subtitle">Fokusér kun på nye beskeder. Eller lad vær. Det er bare et enkelt tryk væk for at skifte mellem alle e-mails og kun de ulæste.</string>
  <string name="spotlight_screen_category_view_main_b2b_title">Hold dig opdateret på nye og ulæste e-mails</string>
  <string name="spotlight_screen_category_view_main_b2b_subtitle">Ulæst-filteret er nu mere tydeligt og nemmere at tilgå, så du lettere kan gennemgå og handle på ulæste e-mails.</string>
  <string name="spotlight_screen_category_view_secondary_b2c_title">Se frem til en mere ryddelig indbakke</string>
  <string name="spotlight_screen_category_view_secondary_b2c_subtitle">Med nye e-mail-kategorier lander kun vigtige beskeder i din primære indbakke. Alt andet organiseres i kategorier.</string>
  <string name="spotlight_screen_category_view_secondary_b2b_title">Hej kategorier.\nFarvel forstyrrelser</string>
  <string name="spotlight_screen_category_view_secondary_b2b_subtitle">Undgå forstyrrelser fra nyhedsbreve, opdateringer, og e-mails der ikke er vigtige. Med de nye e-mail-kategorier er det kun vigtige beskeder der lander i din primære indbakke.</string>
  <string name="spotlight_screen_category_view_button_continue">Hej kategorier.\nFarvel forstyrrelser</string>
  <string name="spotlight_screen_category_view_button_try">Prøv kategorier</string>
  <string name="spotlight_screen_category_view_button_dismiss">Fortsæt uden kategorier</string>
</resources>
